# Omni Link Website - Environment Variables
# Copy to .env.local and fill with real values. Never commit .env.local.

# Contact form (Formspree / Netlify Forms / custom API)
# NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxx
# NEXT_PUBLIC_CONTACT_API_URL=/api/contact

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase (if added later)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
